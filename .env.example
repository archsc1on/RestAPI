DATABASE_URL="your-database-url"
NEXTAUTH_SECRET="nextauth-secret"
NEXTAUTH_URL="nextauth-url"

XENDIT_SECRET_KEY="xnd_development_your-secret-key"
XENDIT_PUBLIC_KEY="xnd_public_your-public-key"
XENDIT_CALLBACK_URL="xnd-callback-url"

GOOGLE_CLIENT_ID="google-client-id"
GOOGLE_CLIENT_SECRET="google-client-secret"
GITHUB_CLIENT_ID="github-client-id"
GITHUB_CLIENT_SECRET="github-client-secret"

# Email (for OTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="email-smtp-user"
SMTP_PASS="email-smtp-pass"
SMTP_FROM="email-smtp-from"

# Security
JWT_SECRET="jwt-secret-key"
ENCRYPTION_KEY="encryption-key"
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL="debug"

# Redis (optional)
REDIS_URL="redis://localhost:6379"

# YouTube API (optional, for yt-search)
YOUTUBE_API_KEY="youtube-api-key"
OMDB_API_KEY="omdb-api-key"

# === COBALT (Downloader) ===
COBALT_API_URL="https://cobalt.dzakii.my.id"
COBALT_API_KEY=""

# === WAIFU.IM ===
WAIFU_API_URL="https://api.waifu.im"
WAIFU_API_KEY="waifu-api-key"

# === NASA API ===
NASA_API_KEY="nasa-api-key"

# === NEWSDATA API ===
NEWSDATA_API_KEY="newsdata-api-key"

# === AERODATABOX (Flight) ===
AERODATABOX_API_KEY="aerodatabox-api-key"

# === GITHUB TRENDING ===
GITHUB_TRENDING_API_URL="https://api.gitterapp.com/repositories"

# === SITE BRANDING ===
NEXT_PUBLIC_SITE_NAME="api-site-name"
NEXT_PUBLIC_API_URL="domain-api-url"
