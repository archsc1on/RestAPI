generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  password        String?
  image           String?
  provider        String?
  providerId      String?

  emailVerified   Boolean  @default(false)
  otp             String?
  otpExpires      DateTime?

  credits         Int      @default(100)
  creditsTier     String   @default("FREE")
  creditsReset    DateTime @default(now())

  role            String   @default("USER")
  isActive        Boolean  @default(true)
  lastLogin       DateTime?

  apiKeys         ApiKey[]
  logs            ApiLog[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([email])
  @@index([provider])
  @@index([creditsTier])
}

model ApiKey {
  id              String   @id @default(cuid())
  key             String   @unique
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  description     String?

  tier            String   @default("FREE")
  creditsDaily    Int      @default(100)
  creditsUsed     Int      @default(0)
  creditsReset    DateTime @default(now())
  rateLimit       Int      @default(30)

  isActive        Boolean  @default(true)
  ipWhitelist     String?

  totalRequests   Int      @default(0)
  successRequests Int      @default(0)
  failedRequests  Int      @default(0)
  lastUsed        DateTime?

  logs            ApiLog[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([key])
  @@index([userId])
  @@index([isActive])
  @@index([createdAt])
}

model ApiLog {
  id            String   @id @default(cuid())

  keyId         String
  key           ApiKey   @relation(fields: [keyId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint      String
  method        String
  platform      String?
  phoneNumber   String?
  messageLength Int?

  statusCode    Int
  errorMessage  String?
  costCredits   Int      @default(1)

  ip            String?
  userAgent     String?

  createdAt     DateTime @default(now())

  @@index([keyId])
  @@index([userId])
  @@index([endpoint])
  @@index([statusCode])
  @@index([createdAt])
}
